       "['cli',\n",
       " 'ili',\n",
       " 'hh_cmnty_cli',\n",
       " 'nohh_cmnty_cli',\n",
       " 'tested_positive',\n",
       " 'cli.1',\n",
       " 'ili.1',\n",
       " 'hh_cmnty_cli.1',\n",
       " 'nohh_cmnty_cli.1',\n",
       " 'tested_positive.1',\n",
       " 'cli.2',\n",
       " 'ili.2',\n",
       " 'hh_cmnty_cli.2',\n",
       " 'nohh_cmnty_cli.2',\n",
       " 'cli_pos_inter',\n",
