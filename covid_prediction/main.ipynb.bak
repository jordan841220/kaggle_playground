  {
   "cell_type": "markdown",
   "id": "02829ddb",
   "metadata": {},
   "source": [
    "## 轉換 Tensor 並傳遞"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ae0366c4",
   "metadata": {},
   "outputs": [],
   "source": [
    "## ----------- Train Data -----------\n",
    "Xtr = torch.tensor(Xtr_s, dtype=torch.float32)\n",
    "ytr = torch.tensor(y_train, dtype=torch.float32).view(-1, 1)\n",
    "\n",
    "## ----------- Validation Data -----------\n",
    "Xva = torch.tensor(Xva_s, dtype=torch.float32)\n",
    "yva = torch.tensor(y_val, dtype=torch.float32).view(-1, 1)\n",
    "\n",
    "\n",
    "## ----------- model ----------- \n",
    "### initial parameters\n",
    "seed = 2026\n",
    "set_seed(seed)\n",
    "model = MultiTaskMLP(input_dim = Xtr.shape[1],\n",
    "                     hidden = 64,\n",
    "                     dropout = 0.2,\n",
    "                     n_layers = 2,\n",
    "                     residual = False\n",
    "        )\n",
    "lr = 1e-3\n",
    "bs = 20\n",
    "epochs = 10000\n",
    "patience = 10\n",
    "bad_count = 0\n",
    "alpha = 0.05\n",
    "alpha_torch = alpha / Xtr.shape[0]\n",
    "train_hist, val_hist, grad_norm_hist = [], [], []\n",
    "best_epoch, best_state = None, None\n",
    "\n",
    "### training\n",
    "opt = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=0.5)\n",
    "scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(opt, T_max=epochs, eta_min=lr/100)\n",
    "train_loader = make_loader(Xtr, ytr, batch_size=bs, seed=seed)\n",
    "\n",
    "for ep in range(epochs):\n",
    "    model.train()\n",
    "    \n",
    "    for batch in train_loader:\n",
    "        \n",
    "        xb, yb = batch\n",
    "        \n",
    "        # Input Noise\n",
    "        noise = torch.randn_like(xb) * 0.005\n",
    "\n",
    "        pred = model(xb)\n",
    "\n",
    "        mse = F.mse_loss(pred, yb)\n",
    "        l2 = sum(p.pow(2).sum() for name, p in model.named_parameters() if include_bias or not name.endswith(\"bias\"))\n",
    "        loss =  mse + alpha * l2\n",
    "\n",
    "        opt.zero_grad()\n",
    "        loss.backward()\n",
    "        opt.step()\n",
    "    \n",
    "    scheduler.step()\n",
    "\n",
    "    with torch.no_grad():\n",
    "        gn = sum(p.grad.pow(2).sum().item() for p in model.parameters() if p.grad is not None)**0.5\n",
    "\n",
    "        model.eval()\n",
    "\n",
    "        p_tr = model(Xtr)\n",
    "        p_va = model(Xva)\n",
    "\n",
    "        real_tr_mse = F.mse_loss(p_tr, ytr).item()\n",
    "        real_va_mse = F.mse_loss(p_va, yva).item()\n",
    "\n",
    "###########################################"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d7bd689f",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "def make_folds(n: int, K: int, shuffle_seed: int):\n",
    "    if n % K == 0:\n",
    "        data_len_each_fold = n // K\n",
    "    else:\n",
    "        # sys.exit()\n",
    "        data_len_each_fold = n // K\n",
    "\n",
    "    idx = np.arange(n)\n",
    "    rng = np.random.default_rng(shuffle_seed)\n",
    "    rng.shuffle(idx)\n",
    "    \n",
    "    folds = []\n",
    "    for k in range(K):\n",
    "        start_idx = k*data_len_each_fold\n",
    "        end_idx = (k+1)*data_len_each_fold if k != K-1 else n\n",
    "        val_idx = idx[start_idx : end_idx]\n",
    "        train_idx = np.concatenate([idx[:start_idx], idx[end_idx:]])\n",
    "        folds.append((train_idx, val_idx))\n",
    "    return folds\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "def eval_config_cv(train_data, \n",
    "                    config: dict, seeds=(8,42,64),\n",
    "                    target_col=\"tested_positive.2\", \n",
    "                    drop_cols=(\"id\", \"tested_positive.2\"),\n",
    "                    return_curves=True):\n",
    "\n",
    "    n = len(train_data)\n",
    "    K = int(config.get(\"fold\", 10))\n",
    "    folds = make_folds(n, K, shuffle_seed=42)\n",
    "\n",
    "    fold_scores = []\n",
    "    fold_rep_runs = []\n",
    "    fold_train_curves = []\n",
    "    fold_val_curves = []\n",
    "    fold_selected_features = []\n",
    "\n",
    "    for (tr_idx, va_idx) in folds:\n",
    "        tr_df = train_data.iloc[tr_idx].reset_index(drop=True)\n",
    "        va_df = train_data.iloc[va_idx].reset_index(drop=True)\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "        ### ---- Train Data ---- ######################\n",
    "        X_train = tr_df.drop(columns=list(drop_cols))\n",
    "        y_train_day3 = [target_col].to_numpy(np.float32)\n",
    "\n",
    "        ## 最終是預測 y3 - y2 的差異\n",
    "        y_train_day2 = tr_df['tested_positive.1'].to_numpy(np.float32)\n",
    "        y_train_delta = (y_train_day3 - y_train_day2)*5\n",
    "\n",
    "        ## Day 2 輔助目標 (預測 Day 2 - Day 1 的變化)\n",
    "        y_train_day1 = tr_df['tested_positive'].to_numpy(np.float32)\n",
    "        y_train_delta_day2 = (y_train_day2 - y_train_day1)*10\n",
    "        ###############################################\n",
    "\n",
    "\n",
    "        ### ---- Validation Data ---- ######################\n",
    "        X_val = va_df.drop(columns=list(drop_cols))\n",
    "        y_val_day3 = va_df[target_col].to_numpy(np.float32)\n",
    "\n",
    "        ## 最終是預測 y3 - y2 的差異\n",
    "        y_val_day2 = va_df['tested_positive.1'].to_numpy(np.float32)\n",
    "        y_val_delta = (y_val_day3 - y_val_day2)*10\n",
    "\n",
    "        ## Day 2 輔助目標 (預測 Day 2 - Day 1 的變化)\n",
    "        y_val_day1 = va_df['tested_positive'].to_numpy(np.float32)\n",
    "        y_val_delta_day2 = (y_val_day2 - y_val_day1)*10\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "        ############### Add Delta #####################\n",
    "        X_train = add_delta(X_train)\n",
    "        X_val = add_delta(X_val)\n",
    "        ###############################################\n",
    "\n",
    "\n",
    "        ############ Normalization ##################\n",
    "        scaler = StandardScaler()\n",
    "        Xtr_s = scaler.fit_transform(X_train)\n",
    "        Xva_s = scaler.transform(X_val)\n",
    "        ###############################################\n",
    "\n",
    "\n",
    "\n",
    "        ######### k feature selection ##############\n",
    "        k = config.get(\"k_best\", None)  \n",
    "        if (k is not None) and (Xtr_s.shape[1] > 0):\n",
    "            k_eff = min(int(k), Xtr_s.shape[1])\n",
    "            selector = SelectKBest(score_func=f_regression, k=k_eff)\n",
    "            Xtr_s = selector.fit_transform(Xtr_s, y_train_delta)\n",
    "            Xva_s = selector.transform(Xva_s)\n",
    "            idx_sel = selector.get_support(indices=True)\n",
    "            selected_sel_cols = X_train.columns[idx_sel].tolist()\n",
    "            fold_selected_features.append(selected_sel_cols)\n",
    "        ###############################################\n",
    "\n",
    "        #############  轉換 Tensor 並傳遞 ################\n",
    "        ## ----------- Train Data -----------\n",
    "        Xtr = torch.tensor(Xtr_s, dtype=torch.float32)\n",
    "        ytr = torch.tensor(y_train_delta, dtype=torch.float32).view(-1, 1)\n",
    "\n",
    "        ## Day 2 輔助目標 (預測 Day 2 - Day 1 的變化)\n",
    "        ytr_aux = torch.tensor(y_train_delta_day2, dtype=torch.float32).view(-1, 1)\n",
    "\n",
    "        ## ----------- Validation Data -----------\n",
    "        Xva = torch.tensor(Xva_s, dtype=torch.float32)\n",
    "        yva = torch.tensor(y_val_delta, dtype=torch.float32).view(-1, 1)\n",
    "\n",
    "        ## Day 2 輔助目標 (預測 Day 2 - Day 1 的變化)\n",
    "        yva_aux = torch.tensor(y_val_delta_day2, dtype=torch.float32).view(-1, 1)\n",
    "\n",
    "\n",
    "        out = train_one_config_multi_seed(Xtr, ytr, Xva, yva, config, seeds=seeds,  ytr_aux=ytr_aux, yva_aux=yva_aux)\n",
    "        ###############################################\n",
    "\n",
    "\n",
    "\n",
    "        fold_scores.append(out['avg_val_mse'])\n",
    "        fold_rep_runs.append(out[\"best_run\"])\n",
    "        \n",
    "        if return_curves:\n",
    "            seed_train = [np.array(r[\"train_mse_hist\"], dtype=float) for r in out[\"all_runs\"]]\n",
    "            seed_val   = [np.array(r[\"val_mse_hist\"], dtype=float)   for r in out[\"all_runs\"]]\n",
    "            min_len = min(map(len, seed_train + seed_val))\n",
    "            fold_train_curves.append(np.stack([x[:min_len] for x in seed_train], axis=0).mean(axis=0))\n",
    "            fold_val_curves.append(np.stack([x[:min_len] for x in seed_val], axis=0).mean(axis=0))\n",
    "\n",
    "    avg_cv_mse = float(np.mean(fold_scores))\n",
    "    sd_cv_mse = float(np.std(fold_scores))\n",
    "    rep_fold = int(np.argmin(fold_scores))\n",
    "    rep_run = {**fold_rep_runs[rep_fold], \"avg_cv_mse\": avg_cv_mse}\n",
    "    \n",
    "    if not return_curves:\n",
    "        return avg_cv_mse, sd_cv_mse, rep_run, fold_selected_features\n",
    "    \n",
    "    min_len_all = min(len(x) for x in fold_train_curves)\n",
    "    fold_train_mat = np.stack([x[:min_len_all] for x in fold_train_curves], axis=0)\n",
    "    fold_val_mat   = np.stack([x[:min_len_all] for x in fold_val_curves], axis=0)\n",
    "\n",
    "    cv_curve = {\n",
    "        \"name\": config.get(\"name\", config[\"model_type\"]),\n",
    "        \"avg_cv_mse\": avg_cv_mse,\n",
    "        \"train_mean\": fold_train_mat.mean(axis=0),\n",
    "        \"val_mean\": fold_val_mat.mean(axis=0),\n",
    "        \"selected_features_per_fold\": fold_selected_features\n",
    "    }\n",
    "    return avg_cv_mse, sd_cv_mse, rep_run, cv_curve\n",
    "\n",
    "def train_one_config_multi_seed(Xtr, ytr, Xva, yva, config: dict, seeds=(8, 42, 64), ytr_aux=None, yva_aux=None ):\n",
    "    \n",
    "    runs = [train_one_run(Xtr, ytr, Xva, yva, config, seed=s, loss_fn=huber_l2, ytr_aux=ytr_aux, yva_aux=yva_aux) for s in seeds]\n",
    "    \n",
    "    avg_val_mse = np.mean([run[\"best_val_mse\"] for run in runs])\n",
    "    best_run = min(runs, key=lambda r: r[\"best_val_mse\"])\n",
    "    return {\"avg_val_mse\": avg_val_mse, \"best_run\": best_run, \"all_runs\": runs}\n",
    "\n",
    "class ScaledSigmoid(nn.Module):\n",
    "    def forward(self, x): return torch.sigmoid(x) * 100.0\n",
    "\n",
    "class ResidualBlock(nn.Module):\n",
    "    def __init__(self, dim, dropout):\n",
    "        super().__init__()\n",
    "        self.block = nn.Sequential(\n",
    "            nn.Linear(dim, dim),\n",
    "            nn.BatchNorm1d(dim),\n",
    "            nn.GELU(),\n",
    "            nn.Dropout(dropout)\n",
    "        )\n",
    "    def forward(self, x): return x + self.block(x)\n",
    "\n",
    "\n",
    "\n",
    "class MultiTaskMLP(nn.Module):\n",
    "    def __init__(self, input_dim, hidden=64, dropout=0.0, n_layers=1, residual=False):\n",
    "        super().__init__()\n",
    "        # Shared Trunk (共享層)\n",
    "        self.trunk = nn.Sequential(\n",
    "            nn.Linear(input_dim, hidden),\n",
    "            nn.BatchNorm1d(hidden),\n",
    "            nn.GELU(),\n",
    "            nn.Dropout(dropout)\n",
    "        )\n",
    "        # 根據層數堆疊\n",
    "        trunk_layers = []\n",
    "        for _ in range(n_layers - 1):\n",
    "            if residual: \n",
    "                trunk_layers.append(ResidualBlock(hidden, dropout))\n",
    "            else: \n",
    "                trunk_layers.append(nn.Sequential(\n",
    "                                        nn.Linear(hidden, hidden), \n",
    "                                        nn.BatchNorm1d(hidden), \n",
    "                                        nn.GELU(), \n",
    "                                        nn.Dropout(dropout)\n",
    "                                        )\n",
    "                                    )\n",
    "        self.deep_trunk = nn.Sequential(*trunk_layers)\n",
    "\n",
    "        # Head 1: Main Task (Day 3)\n",
    "        self.head_main = nn.Sequential(\n",
    "            nn.Linear(hidden, 1)\n",
    "        )\n",
    "        \n",
    "        # Head 2: Aux Task (Day 2)\n",
    "        self.head_aux = nn.Sequential(\n",
    "            nn.Linear(hidden, 1)\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        feat = self.trunk(x)\n",
    "        feat = self.deep_trunk(feat)\n",
    "        return self.head_main(feat), self.head_aux(feat)\n",
    "\n",
    "\n",
    "\n",
    "def build_model(input_dim:int, config: dict) -> nn.Module:\n",
    "    mtype = config[\"model_type\"]\n",
    "    if mtype == \"linear\":\n",
    "        return nn.Sequential(nn.Linear(input_dim, 1), ScaledSigmoid())\n",
    "    elif mtype == \"mlp\":\n",
    "        # [Mod] 改用 MultiTaskMLP\n",
    "        return MultiTaskMLP(\n",
    "            input_dim=input_dim,\n",
    "            hidden=config.get(\"hidden\", 64),\n",
    "            dropout=config.get(\"dropout\", 0.0),\n",
    "            n_layers=config.get(\"layer\", 1),\n",
    "            residual=config.get(\"residual\", False)\n",
    "        )\n",
    "    return None\n",
    "\n",
    "def mse_l2(pred, target, model, alpha=0.0, include_bias=False):\n",
    "    mse = F.mse_loss(pred, target)\n",
    "    if alpha == 0.0: return mse\n",
    "    l2 = sum(p.pow(2).sum() for name, p in model.named_parameters() if include_bias or not name.endswith(\"bias\"))\n",
    "    return mse + alpha * l2\n",
    "\n",
    "def huber_l2(pred, target, model, alpha=0.0, include_bias=False, weights=None):\n",
    "    huber = F.huber_loss(pred, target, delta=0.1, reduction='none')\n",
    "\n",
    "    if weights is not None:\n",
    "        huber = huber * weights\n",
    "    \n",
    "    huber = huber.mean()\n",
    "\n",
    "    if alpha == 0.0:\n",
    "        return huber\n",
    "    # 保留 L2 正則化部分調教\n",
    "    l2 = sum(p.pow(2).sum() for name, p in model.named_parameters() if include_bias or not name.endswith(\"bias\"))\n",
    "    return huber + alpha * l2\n",
    "\n",
    "\n",
    "def train_one_run(Xtr, ytr, Xva, yva, config: dict, seed: int, build_model_fn=build_model, loss_fn=mse_l2, ytr_aux=None, yva_aux=None):\n",
    "    set_seed(seed)\n",
    "    model = build_model_fn(Xtr.shape[1], config)\n",
    "    lr, bs, epochs = float(config.get(\"lr\", 1e-3)), int(config.get(\"batch_size\", 20)), int(config.get(\"epochs\", 800))\n",
    "    patience, alpha = int(config.get(\"patience\", 10)), float(config.get(\"alpha\", 0.0))\n",
    "\n",
    "    aux_weight = float(config.get(\"aux_weight\", 0.2))\n",
    "    \n",
    "    opt = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=0.5)\n",
    "    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(opt, T_max=epochs, eta_min=lr/100)\n",
    "    \n",
    "    train_loader = make_loader(Xtr, ytr, batch_size=bs, seed=seed, ytr_aux=ytr_aux)\n",
    "\n",
    "    best_val, bad_count, alpha_torch = float(\"inf\"), 0, alpha / Xtr.shape[0]\n",
    "    train_hist, val_hist, grad_norm_hist = [], [], []\n",
    "    best_epoch, best_state = None, None\n",
    "\n",
    "    for ep in range(epochs):\n",
    "        model.train()\n",
    "        for batch in train_loader:\n",
    "            if len(batch) == 3:\n",
    "                xb, yb, yb_aux = batch\n",
    "            else:\n",
    "                xb, yb = batch\n",
    "                yb_aux = None\n",
    "            \n",
    "            # Input Noise\n",
    "            noise = torch.randn_like(xb) * 0.005\n",
    "            \n",
    "            \n",
    "            if isinstance(model, MultiTaskMLP):\n",
    "                pred_main, pred_aux = model(xb + noise)\n",
    "                loss_main = loss_fn(pred_main, yb, model, alpha=alpha_torch)\n",
    "            \n",
    "\n",
    "                if yb_aux is not None:\n",
    "                    loss_aux = F.mse_loss(pred_aux, yb_aux) # Aux loss 通常不用加 L2\n",
    "                    loss = loss_main + aux_weight * loss_aux\n",
    "                else:\n",
    "                    loss = loss_main\n",
    "                \n",
    "            else:\n",
    "                loss = loss_fn(model(xb + noise), yb, model, alpha=alpha_torch)\n",
    "\n",
    "\n",
    "\n",
    "            opt.zero_grad()\n",
    "            loss.backward()\n",
    "            opt.step()\n",
    "        \n",
    "        scheduler.step()\n",
    "        \n",
    "        with torch.no_grad():\n",
    "            gn = sum(p.grad.pow(2).sum().item() for p in model.parameters() if p.grad is not None)**0.5\n",
    "            grad_norm_hist.append(gn)\n",
    "            \n",
    "            model.eval()\n",
    "            # 1. 取得預測值與目標\n",
    "            if isinstance(model, MultiTaskMLP):\n",
    "                p_tr, _ = model(Xtr)\n",
    "                p_va, _ = model(Xva)\n",
    "            else:\n",
    "                p_tr = model(Xtr)\n",
    "                p_va = model(Xva)\n",
    "            \n",
    "            # 2. 計算原始尺度的 MSE (除以 5 還原後再算 MSE)\n",
    "            real_tr_mse = F.mse_loss(p_tr / 10.0, ytr / 10.0).item()\n",
    "            real_va_mse = F.mse_loss(p_va / 10.0, yva / 10.0).item()\n",
    "            \n",
    "        train_hist.append(real_tr_mse)\n",
    "        val_hist.append(real_va_mse)\n",
    "\n",
    "        if real_va_mse < best_val - 1e-4:\n",
    "            best_val, bad_count, best_epoch = real_va_mse, 0, ep\n",
    "            best_state = {k: v.detach().clone() for k, v in model.state_dict().items()}\n",
    "        else:\n",
    "            bad_count += 1\n",
    "            if bad_count >= patience: break\n",
    "    \n",
    "    return {\"seed\": seed, \"alpha\": alpha, \"config\": config, \n",
    "    \"best_val_mse\": best_val, \"best_epoch\": best_epoch, \n",
    "    \"best_state\": best_state, \"train_mse_hist\": train_hist, \n",
    "    \"val_mse_hist\": val_hist, \"grad_norm_hist\": grad_norm_hist}\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a54a35c3",
   "metadata": {},
   "source": [
    "### 最外層"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 119,
   "id": "2c20d789",
   "metadata": {},
   "outputs": [],
   "source": [
    "import plotly.express as px\n",
    "\n",
    "def sweep_k_cv(train_data, configs, seeds=(8,42,64)):\n",
    "    all_results = []  # 用來收集所有模型的資料\n",
    "    \n",
    "    for cfg in configs:\n",
    "        k = cfg.get(\"k_best\", None)\n",
    "        model_name = cfg.get(\"name\")\n",
    "        print(f\"[k={k}] Running model {model_name}...\")\n",
    "\n",
    "        # 這裡改回用 eval_config_cv\n",
    "        avg_cv_mse, sd_cv_mse, rep_run, fold_selected_features = eval_config_cv(\n",
    "            train_data, config=cfg, seeds=seeds,\n",
    "            return_curves=False\n",
    "        )\n",
    "\n",
    "        # 把所有結果存進 list\n",
    "\n",
    "        all_results.append({\n",
    "            \"name\": model_name,\n",
    "            \"mse\": avg_cv_mse,\n",
    "            \"sd\": sd_cv_mse,\n",
    "            \"k\": k,\n",
    "            \"hidden\": cfg.get(\"hidden\", \"N/A\"),\n",
    "            \"alpha\": cfg.get(\"alpha\", \"N/A\"),\n",
    "            \"dropout\": cfg.get(\"dropout\", \"N/A\"),\n",
    "            \"lr\": cfg.get(\"lr\", \"N/A\"),\n",
    "            \"layer\": cfg.get(\"layers\", \"N/A\"),\n",
    "            \"aux_weight\":  cfg.get(\"aux_weight\", \"N/A\")\n",
    "        })\n",
    "\n",
    "    df = pd.DataFrame(all_results)\n",
    "    return df\n",
    "\n",
    "def plot_sweep_k_cv(df, color_by=k):\n",
    "    \n",
    "    # 建立互動式散點圖\n",
    "    fig = px.scatter(\n",
    "        df, \n",
    "        x=\"mse\", \n",
    "        y=\"sd\", \n",
    "        color=str(color_by),\n",
    "        hover_name=\"name\",       # 滑鼠移上去顯示模型完整名稱\n",
    "        hover_data=[\"k\", \"hidden\", \"alpha\", \"dropout\", \"lr\"],\n",
    "        title=\"Model Performance vs Stability (Interactive)\",\n",
    "        labels={\"mse\": \"CV MSE\", \"sd\": \"Standard Deviation (SD)\"},\n",
    "        template=\"plotly_white\"\n",
    "    )\n",
    "    # --- 加入門檻線 (Thresholds) ---\n",
    "    # 畫垂直線 (MSE 門檻)\n",
    "    fig.add_vline(x=1.045, line_dash=\"dash\", line_color=\"red\", \n",
    "                  annotation_text=\"MSE Limit\", annotation_position=\"top left\")\n",
    "    \n",
    "    # 畫水平線 (SD 穩定度門檻)\n",
    "    fig.add_hline(y=0.115, line_dash=\"dash\", line_color=\"green\", \n",
    "                  annotation_text=\"SD Limit\", annotation_position=\"top right\")\n",
    "\n",
    "                  \n",
    "    # 優化視覺：把點變大一點，比較好點擊\n",
    "    fig.update_traces(marker=dict(size=12, line=dict(width=2, color='DarkSlateGrey')))\n",
    "    \n",
    "    fig.show()\n",
    "    \n",
    "    return\n"
   ]
  },
