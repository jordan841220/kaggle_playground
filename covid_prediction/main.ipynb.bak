   "cell_type": "markdown",
   "id": "64694f10",
   "metadata": {},
   "source": [
    "### 用上面的 model 的 pred，上傳看分數如何"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a82b636a",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "\n",
    "def fit_preprocess_train_final(\n",
    "    train_df,\n",
    "    config: dict,\n",
    "    num_real: int,\n",
    "    target_col=\"tested_positive.2\",\n",
    "    drop_cols=(\"id\", \"tested_positive.2\"),\n",
    "):  \n",
    "    weights = None\n",
    "    weights_real = None\n",
    "    if 'sample_weight' in train_df.columns:\n",
    "        weights = torch.tensor(train_df['sample_weight'].values, dtype=torch.float32).view(-1, 1)\n",
    "        weights_real = weights[:num_real]\n",
    "        drop_cols = list(drop_cols) + ['sample_weight']\n",
    "    \n",
    "    X = train_df.drop(columns=list(drop_cols))\n",
    "    # 這裡也要加上 Delta 特徵，確保與 eval_config_cv 一致\n",
    "    X = add_delta(X)\n",
    "    \n",
    "    ## ---- 改為預測 y3 - y2 的差異\n",
    "    y_day3 = train_df[target_col].to_numpy(np.float32)\n",
    "    y_day2 = train_df['tested_positive.1'].to_numpy(np.float32)\n",
    "    y_delta = (y_day3 - y_day2)*10\n",
    "\n",
    "\n",
    "\n",
    "    scaler = StandardScaler()\n",
    "    # 只用前 num_real 筆（真實資料）來 fit\n",
    "    scaler.fit(X.iloc[:num_real]) \n",
    "    X_s = scaler.transform(X).astype(np.float32)\n",
    "\n",
    "    k_best = config.get(\"k_best\", None)\n",
    "    selector = None\n",
    "    \n",
    "    \n",
    "    \n",
    "    feature_names = X.columns.tolist()\n",
    "    if (k_best is not None) and (X_s.shape[1] > 0):\n",
    "        k_eff = min(int(k_best), X_s.shape[1])\n",
    "        selector = SelectKBest(score_func=f_regression, k=k_eff)\n",
    "        \n",
    "        # --- 只用真實資料的 X, y 來決定特徵 ---\n",
    "        selector.fit(X_s[:num_real], y_delta[:num_real]) \n",
    "        X_s = selector.transform(X_s).astype(np.float32)\n",
    "\n",
    "        idx_sel = selector.get_support(indices=True)\n",
    "        feature_names = [feature_names[i] for i in idx_sel]\n",
    "\n",
    "    Xtr = torch.tensor(X_s, dtype=torch.float32)\n",
    "    ytr = torch.tensor(y_delta, dtype=torch.float32).view(-1, 1)\n",
    "\n",
    "    ### 預先切分出真實資料暫存\n",
    "    X_real = Xtr[:num_real]\n",
    "    y_real = ytr[:num_real]\n",
    "\n",
    "    model = build_model(Xtr.shape[1], config)\n",
    "    lr = float(config.get(\"lr\", 1e-3))\n",
    "    epochs = int(config.get(\"final_epochs\", config.get(\"epochs\", 200)))\n",
    "    alpha = float(config.get(\"alpha\", 0.0))\n",
    "    alpha_torch = alpha / Xtr.shape[0]\n",
    "\n",
    "    opt = torch.optim.Adam(model.parameters(), lr=lr, weight_decay=0)\n",
    "    # 這裡也加入 Scheduler\n",
    "    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(opt, T_max=epochs, eta_min=lr/100)\n",
    "\n",
    "    ### training\n",
    "    for ep in range(epochs):\n",
    "        model.train()\n",
    "\n",
    "        ## 不做 pseudo data 分批訓練因為沒有 pseudo data\n",
    "        if len(X_real) == len(Xtr):\n",
    "            curr_X, curr_y = Xtr, ytr\n",
    "            curr_weights = None\n",
    "        else:\n",
    "            # 前 70% 的時間：使用包含 Pseudo data 的「全量數據」\n",
    "            if ep < epochs * 0.7:\n",
    "                curr_X, curr_y = Xtr, ytr\n",
    "                curr_weights = weights\n",
    "            else:\n",
    "                curr_X, curr_y = X_real, y_real\n",
    "                curr_weights = weights_real\n",
    "\n",
    "        \n",
    "\n",
    "        # --- 新增：Input Noise ---\n",
    "        # 為了不影響原始 Xtr，我們每次循環都加在一個暫存變數上\n",
    "        noise = torch.randn_like(curr_X) * 0.005 \n",
    "        curr_X_noisy = curr_X + noise\n",
    "\n",
    "        if isinstance(model, MultiTaskMLP):\n",
    "            pred_main, _ = model(curr_X_noisy)\n",
    "            loss = huber_l2(pred_main, curr_y, model, alpha=alpha_torch, weights=curr_weights)\n",
    "        else:\n",
    "            pred = model(curr_X_noisy)\n",
    "            loss = huber_l2(pred, curr_y, model, alpha=alpha_torch, weights=curr_weights)\n",
    "        opt.zero_grad()\n",
    "        loss.backward()\n",
    "        opt.step()\n",
    "        scheduler.step()\n",
    "\n",
    "    return model, scaler, selector, feature_names\n",
    "\n",
    "def predict_test(\n",
    "    model,\n",
    "    test_df,\n",
    "    scaler,\n",
    "    selector,\n",
    "    drop_cols=(\"id\"),\n",
    "):\n",
    "    drop_cols = [c for c in drop_cols if c in test_df.columns]\n",
    "    X_test = test_df.drop(columns=drop_cols)\n",
    "\n",
    "    # 預測時也必須加入 Delta 特徵\n",
    "    X_test = add_delta(X_test)\n",
    "\n",
    "    X_test_s = scaler.transform(X_test).astype(np.float32, copy=False)\n",
    "    \n",
    "    if (selector is not None):\n",
    "        X_test_s = selector.transform(X_test_s).astype(np.float32, copy=False)\n",
    "\n",
    "    Xte = torch.tensor(X_test_s, dtype=torch.float32)\n",
    "    \n",
    "    model.eval()\n",
    "    with torch.no_grad():\n",
    "\n",
    "        if isinstance(model, MultiTaskMLP):\n",
    "            pred_main, _ = model(Xte)\n",
    "            pred_delta = pred_main.view(-1).cpu().numpy() / 5\n",
    "        else:\n",
    "            pred_delta = model(Xte).view(-1).cpu().numpy() / 5\n",
    "    \n",
    "    # 將增長量加回到「昨天的確診數」\n",
    "    y_prev_test = test_df['tested_positive.1'].values\n",
    "    final_pred = y_prev_test + pred_delta\n",
    "\n",
    "    return final_pred\n"
   ]
  },
