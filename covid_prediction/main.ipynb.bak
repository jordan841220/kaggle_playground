   "source": [
    "### 看一下 model 的 feature selection 結果（5 fold cross validation）"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 122,
   "id": "80b29477",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "INFO: 總共涉及 32 個不同的特徵。\n",
      "INFO: Fold 數量 = 5\n",
      "INFO: 5.0\n",
      "INFO: 1.0\n",
      "------- 穩定特徵數 (全 Fold 出現): 8\n",
      "------- 核心特徵比例: 25.00%\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1200x800 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "\n",
    "def plot_feature_selection_heatmap(cv_curve):\n",
    "    # 1. 取得數據並進行基本檢查\n",
    "    fold_features = cv_curve.get('selected_features_per_fold', [])\n",
    "    if not fold_features:\n",
    "        print(\"警告：cv_curve 中沒有選中的特徵數據！請確認 config 是否包含 'k_best'。\")\n",
    "        return None\n",
    "    num_folds = len(fold_features)\n",
    "\n",
    "    # 2. 統計所有曾被選中的特徵\n",
    "    all_selected = sorted(list(set([f for fold in fold_features for f in fold])))\n",
    "    num_total_selected = len(all_selected)\n",
    "    print(f\"INFO: 總共涉及 {len(all_selected)} 個不同的特徵。\")\n",
    "    print(f\"INFO: Fold 數量 = {len(fold_features)}\")\n",
    "    \n",
    "    # 3. 建立 Matrix (特徵數 x Fold數)\n",
    "    data = np.zeros((len(all_selected), len(fold_features)))\n",
    "    for f_idx, f_name in enumerate(all_selected):\n",
    "        for fold_idx, fold in enumerate(fold_features):\n",
    "            if f_name in fold:\n",
    "                data[f_idx, fold_idx] = 1\n",
    "                \n",
    "    # 4. 建立 DataFrame 並排序\n",
    "    df_heat = pd.DataFrame(data, index=all_selected, columns=[f'Fold {i+1}' for i in range(len(fold_features))])\n",
    "    df_heat['Total'] = df_heat.sum(axis=1)\n",
    "    df_heat = df_heat.sort_values('Total', ascending=False)\n",
    "\n",
    "    core_features_count = (df_heat['Total'] == num_folds).sum()\n",
    "    core_ratio = (core_features_count / num_total_selected) * 100\n",
    "\n",
    "    # 5. 除錯：檢查數據內容\n",
    "    print(f\"INFO: {df_heat['Total'].max()}\")\n",
    "    print(f\"INFO: {df_heat['Total'].min()}\")\n",
    "    print(f\"------- 穩定特徵數 (全 Fold 出現): {core_features_count}\")\n",
    "    print(f\"------- 核心特徵比例: {core_ratio:.2f}%\")\n",
    "    \n",
    "    # 6. 畫圖：增加 vmin/vmax 強制顏色範圍\n",
    "    plt.figure(figsize=(12, max(8, num_total_selected * 0.22)))\n",
    "    \n",
    "    # cmap=\"YlGnBu\": 0=黃色, 1=深藍色\n",
    "    sns.heatmap(df_heat.drop(columns='Total'), \n",
    "                cmap=\"YlGnBu\", \n",
    "                cbar=True,       # 開啟顏色條以確認數值\n",
    "                vmin=0, vmax=1,  # 強制定義範圍\n",
    "                linewidths=.5)\n",
    "    plt.title(f\"Most Stable Features (Selected across Folds)\")\n",
    "    plt.ylabel(\"Feature Names\")\n",
    "    plt.xlabel(\"Validation Folds\")\n",
    "    plt.show()\n",
    "    \n",
    "    return df_heat\n",
    "\n",
    "\n",
    "k = 20\n",
    "layer = 2\n",
    "hidden = 16\n",
    "dropout = 0.1\n",
    "alpha = 0.2\n",
    "batch_size = 50\n",
    "lr = 0.001\n",
    "aux = 0.5\n",
    "\n",
    "config1 = {\"name\": f\"mlp_layers{layer}_hidden{hidden}_drop{dropout}_batch{batch_size}_lr{lr}_fold5_alpha{alpha}_k{k}_aux-weight{aux}\",\n",
    "            \"model_type\": \"mlp\",\n",
    "            \"layers\": layer,\n",
    "            \"hidden\": hidden,\n",
    "            \"dropout\": dropout,\n",
    "            \"alpha\": alpha,\n",
    "            \"lr\": lr,\n",
    "            \"fold\": 5,\n",
    "            \"batch_size\": batch_size,\n",
    "            \"epochs\": 1000,\n",
    "            \"patience\": 50,\n",
    "            \"k_best\": k,\n",
    "            \"final_epochs\": 250000,\n",
    "            \"aux_weight\": aux\n",
    "        }\n",
    "\n",
    "_, _, _, cv_curve = eval_config_cv(train_data, config=config1, return_curves=True)\n",
    "df_ranking = plot_feature_selection_heatmap(cv_curve)"
   ]
  },
