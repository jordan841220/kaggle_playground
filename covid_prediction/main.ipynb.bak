   "source": [
    "seeds = [42, 1, 10, 88, 777]\n",
    "ensemble_preds = []\n",
    "\n",
    "for s in seeds:\n",
    "\n",
    "    print(f\"--- 正在訓練 Seed {s} ---\")\n",
    "    set_seed(s)\n",
    "\n",
    "    final_model, scaler, selector, feature_cols = fit_preprocess_train_final(\n",
    "        train_df=train_data,\n",
    "        config=config1,\n",
    "        num_real=len(train_data),\n",
    "        target_col=\"tested_positive.2\",\n",
    "        drop_cols=(\"id\", \"tested_positive.2\"),\n",
    "    )\n",
    "\n",
    "\n",
    "    # test prediction\n",
    "    test_pred = predict_test(\n",
    "        model=final_model,\n",
    "        test_df=test_data,\n",
    "        scaler=scaler,\n",
    "        selector=selector,\n",
    "        drop_cols=(\"id\",),  # test 通常只有 id 要 drop\n",
    "    )\n",
    "\n",
    "    ensemble_preds.append(test_pred)\n",
    "\n",
    "final_test_pred = np.mean(ensemble_preds, axis=0)\n",
    "\n",
    "sub = pd.DataFrame({\"id\": test_data[\"id\"].values, \"tested_positive\": final_test_pred})\n",
    "sub_csv_name = config1[\"name\"] + \".csv\"\n",
    "sub.to_csv(sub_csv_name, index=False)\n",
    "\n",
    "!kaggle competitions submit -c ml2021spring-hw1 -f {sub_csv_name} -m \"predict d2-d1_delta & d3-d2_delta (both scaled)\""
   ]
