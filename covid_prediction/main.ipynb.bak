    "k = 16 # 選出 16 features\n",
    "\n",
    "\n",
    "k_eff = min(int(k), Xtr_s.shape[1])\n",
    "selector = SelectKBest(score_func=f_regression, k=k_eff)\n",
    "Xtr_s = selector.fit_transform(Xtr_s, y_train) # 看特徵 X 跟目標 y 的關係來打分數\n",
    "Xva_s = selector.transform(Xva_s) # 只保留 fit 時被選中的那些欄位\n",
    "\n",
    "idx_sel = selector.get_support(indices=True)\n",
